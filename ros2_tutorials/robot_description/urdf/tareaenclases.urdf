<?xml version="1.0"?>
<robot name="scara_arm">


  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.025"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0.025"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>



  <link name="link1">
    <visual>
      <geometry>
        <box size="0.35 0.06 0.04"/>
      </geometry>
      
      <origin rpy="0 0 0" xyz="0.175 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.35 0.06 0.04"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.175 0 0"/>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0.175 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.01"  iyz="0" izz="0.01"/>
    </inertial>
  </link>



  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.50" upper="2.50"
           effort="50" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link2">
    <visual>
      <geometry>
        <box size="0.25 0.05 0.04"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.125 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.25 0.05 0.04"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0.125 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.125 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>




  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0.35 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.96706" upper="2.96706"
           effort="30" velocity="1.5"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <link name="spindle_link">
    <visual>
      <geometry>
        <cylinder length="0.2" radius="0.02"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 -0.1"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.2" radius="0.02"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 -0.1"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 -0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>




  <joint name="joint3" type="prismatic">
    <parent link="link2"/>
    <child link="spindle_link"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.15" upper="0.0"
           effort="20" velocity="0.5"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <link name="wrist_link">
    <visual>
      <geometry>
        <cylinder length="0.03" radius="0.025"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 -0.015"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.03" radius="0.025"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 -0.015"/>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 -0.015"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>


  <joint name="joint4" type="revolute">
    <parent link="spindle_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 -0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.95" upper="2.00"
           effort="10" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="end_effector">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="wrist_to_ee" type="fixed">
    <parent link="wrist_link"/>
    <child link="end_effector"/>
    <origin xyz="0 0 -0.03" rpy="0 0 0"/>
  </joint>

</robot>